# ─── Database ────────────────────────────────────────────────────────────────
# Neon pooled connection (for Prisma queries)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/gameshelf?sslmode=require&pgbouncer=true"
# Neon direct connection (for Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/gameshelf?sslmode=require"

# For local development with Docker: uncomment below and comment out Neon URLs
# DATABASE_URL="postgresql://gameshelf:gameshelf@localhost:5432/gameshelf"
# DIRECT_URL="postgresql://gameshelf:gameshelf@localhost:5432/gameshelf"

# ─── NextAuth v5 (Auth.js) ───────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── IGDB (Twitch OAuth) ─────────────────────────────────────────────────────
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="GameShelf <noreply@yourdomain.com>"

# ─── Cloudinary ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
